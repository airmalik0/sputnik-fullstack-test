# Copy to `.env.dev` (already present in the repo with sane defaults)
# and tweak per environment. Variables are consumed by docker-compose
# and read by pydantic-settings on the backend side.

# --- Postgres ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=test
POSTGRES_HOST=backend-db
PGPORT=5433

# --- Celery / Redis ---
CELERY_BROKER_URL=redis://backend-redis:6379/0

# --- API ---
# Comma-separated list. Add the host:port the dev frontend actually
# runs on if you remap ports locally (e.g. via docker-compose.override).
# Defaults are fine for the standard `docker compose up`.
# CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Limit on the size of a `text/*` upload that gets fully decoded for
# line/char counting. Defaults to 5 MiB; raise carefully — this caps
# worker memory.
# TEXT_METADATA_BYTE_LIMIT=5242880

# Threshold above which the scanner flags a file as suspiciously large.
# Defaults to 10 MiB.
# SUSPICIOUS_SIZE_BYTES=10485760
