# Frontend env vars are baked into the Next.js bundle at build time.
# Copy to `.env.production` (for `next build`) or `.env.local` (for
# `next dev`) and set the public host of the backend.

# Default: http://localhost:8000 — works for the standard
# `docker compose up` setup. Override when deploying behind a real
# domain.
NEXT_PUBLIC_API_URL=http://localhost:8000
